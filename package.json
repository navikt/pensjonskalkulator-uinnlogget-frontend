{
  "name": "pensjonskalkulator-uinnlogget-frontend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "next build && pnpm build:server",
    "build:prod": "cp .env.prod .env && next build && pnpm build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "next start",
    "dev": "concurrently -k \"next dev --turbopack\" \"json-server mockdb/db.json --port 3001\"",
    "fetch-dev-types": "openapi-typescript https://pensjonskalkulator-backend.intern.dev.nav.no/v3/api-docs/current -o ./src/types/schema.d.ts",
    "format:types": "prettier --write ./src/types/schema.d.ts && eslint ./src/types/schema.d.ts --fix",
    "test": "jest",
    "testc": "jest --c",
    "typecheck": "tsc --noEmit --pretty -p tsconfig.json && tsc --noEmit --pretty -p tsconfig.server.json",
    "lint": "next lint",
    "prettier:fix": "prettier --write '**/*.{cjs,js,jsx,ts,tsx,json}'",
    "prepare": "if [ -z \"$CI\" ]; then husky; fi"
  },
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@navikt/ds-css": "^7.28.1",
    "@navikt/ds-react": "^7.28.1",
    "@navikt/nav-dekoratoren-moduler": "^3.4.0",
    "@navikt/oasis": "^3.8.0",
    "@navikt/steng-for-regulering": "^0.0.7",
    "express": "^5.2.1",
    "highcharts": "^12.4.0",
    "highcharts-react-official": "^3.2.2",
    "immer": "^10.1.1",
    "next": "^15.5.19",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.33.0",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.3.0",
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.7",
    "babel-jest": "^30.0.5",
    "concurrently": "^9.2.0",
    "eslint": "^9.33.0",
    "eslint-config-next": "15.5.15",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.0.5",
    "jsdom": "^29.0.2",
    "json-server": "^1.0.0-beta.3",
    "lint-staged": "^16.1.5",
    "openapi-typescript": "^7.9.1",
    "prettier": "^3.6.2",
    "typescript": "^5",
    "typescript-eslint": "^8.41.0"
  },
  "lint-staged": {
    "**/*.{cjs,js,jsx,ts,tsx}": "next lint --fix --file",
    "**/*.{cjs,js,jsx,ts,tsx,css}": "prettier --write"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.10",
      "@types/react-dom": "19.1.7",
      "jsdom>parse5": "^7.1.2",
      "postcss@<8.5.14": "8.5.14",
      "ip-address@<=10.1.0": "10.2.0",
      "@ungap/structured-clone@<1.3.1": "1.3.1",
      "lodash": "4.18.1"
    },
    "ignoredBuiltDependencies": [
      "unrs-resolver"
    ]
  }
}
